{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConceptCandidate",
  "type": "object",
  "required": [
    "centroidId",
    "coherence",
    "memberCount",
    "memberIds",
    "stable"
  ],
  "properties": {
    "centroidId": {
      "type": "string"
    },
    "coherence": {
      "type": "number",
      "format": "double"
    },
    "memberCount": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "memberIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stable": {
      "description": "Whether centroid refinement converged (zero reassignments in last pass).",
      "type": "boolean"
    }
  }
}