{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConceptCandidate",
  "type": "object",
  "properties": {
    "centroidId": {
      "type": "string"
    },
    "coherence": {
      "type": "number",
      "format": "double"
    },
    "memberCount": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "memberIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stable": {
      "description": "Whether centroid refinement converged (zero reassignments in last pass).",
      "type": "boolean"
    }
  },
  "required": [
    "centroidId",
    "memberCount",
    "coherence",
    "memberIds",
    "stable"
  ]
}