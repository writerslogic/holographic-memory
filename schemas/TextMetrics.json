{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TextMetrics",
  "type": "object",
  "properties": {
    "consonantCount": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "punctuationCount": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "sentenceCount": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "syllableCount": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "vowelCount": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "wordCount": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "required": [
    "wordCount",
    "sentenceCount",
    "syllableCount",
    "vowelCount",
    "consonantCount",
    "punctuationCount"
  ]
}